project_id   = "my-gcp-project-id"
region       = "europe-west4"
zone         = "europe-west4-a"
vm_name      = "vm-curator"
machine_type = "e2-standard-4"
disk_size_gb = 50
disk_type    = "pd-ssd"

# Obtain from the AUXO Portal (https://soc.on2it.net)
auth_code = "REPLACE_WITH_CURATOR_AUTH_CODE"

# Restrict inbound access to your management network
firewall_allow_ips = ["203.0.113.0/24"]

labels = {
  project     = "auxo-curator"
  environment = "production"
  managedby   = "terraform"
}
